netcdf languages {

dimensions:
    n_lang = 5 ;

variables:
    string languages(n_lang) ;
  string phrase(n_lang) ;

data:

  languages = "English", "Ogham", "Welsh", "Anglo-Saxon", "Braille" ;

  phrase = 
    "Hello World!",
    "/ ᚛᚛ᚉᚑᚅᚔᚉᚉᚔᚋ ᚔᚈᚔ ᚍᚂᚐᚅᚑ ᚅᚔᚋᚌᚓᚅᚐ᚜",
